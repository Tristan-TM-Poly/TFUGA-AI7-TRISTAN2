{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tristan-tm-poly.github.io/schemas/omega_infra_qc_t/maintenance_signal.schema.json",
  "title": "Infrastructure MaintenanceSignal",
  "type": "object",
  "additionalProperties": false,
  "required": ["signal_id", "asset_id"],
  "properties": {
    "signal_id": {"type": "string", "minLength": 1},
    "asset_id": {"type": "string", "minLength": 1},
    "condition_score": {"type": "integer", "minimum": 0, "maximum": 5},
    "service_criticality": {"type": "integer", "minimum": 0, "maximum": 5},
    "maintenance_debt": {"type": "integer", "minimum": 0, "maximum": 5},
    "climate_exposure": {"type": "integer", "minimum": 0, "maximum": 5},
    "cost_of_delay": {"type": "integer", "minimum": 0, "maximum": 5},
    "reversibility": {"type": "integer", "minimum": 0, "maximum": 5},
    "evidence_quality": {"type": "integer", "minimum": 0, "maximum": 5},
    "notes": {"type": "string"},
    "metadata": {"type": "object"}
  }
}
