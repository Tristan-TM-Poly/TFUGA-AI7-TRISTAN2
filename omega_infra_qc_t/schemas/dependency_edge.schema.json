{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tristan-tm-poly.github.io/schemas/omega_infra_qc_t/dependency_edge.schema.json",
  "title": "Infrastructure DependencyEdge",
  "type": "object",
  "additionalProperties": false,
  "required": ["source_asset_id", "target_asset_id", "kind", "confidence", "visibility"],
  "properties": {
    "source_asset_id": {"type": "string", "minLength": 1},
    "target_asset_id": {"type": "string", "minLength": 1},
    "kind": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "visibility": {"type": "string"},
    "evidence_ids": {"type": "array", "items": {"type": "string"}},
    "notes": {"type": "string"},
    "metadata": {"type": "object"}
  }
}
