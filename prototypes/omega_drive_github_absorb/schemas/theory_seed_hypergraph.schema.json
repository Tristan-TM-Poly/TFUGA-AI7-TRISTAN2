{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tristan.systems/schemas/omega-drive-github-absorb/theory_seed_hypergraph.schema.json",
  "title": "Ω-DRIVE-GITHUB-ABSORB-T Theory Seed Hypergraph",
  "type": "object",
  "required": ["nodes", "edges"],
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string"},
          "label": {"type": "string"},
          "risk_level": {"enum": ["low", "medium", "high"]}
        },
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target", "type"],
        "properties": {
          "source": {"type": "string"},
          "target": {"type": "string"},
          "type": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
