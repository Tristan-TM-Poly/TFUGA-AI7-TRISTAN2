{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OAKGate Pull Request Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "pr_id",
    "title",
    "class",
    "product",
    "binding",
    "claims",
    "risk_profile",
    "capabilities",
    "rollback",
    "self_review",
    "evidence"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0.0"},
    "manifest_id": {"type": "string", "pattern": "^PR-[0-9]+$"},
    "pr_id": {"type": "integer", "minimum": 1},
    "title": {"type": "string", "minLength": 1, "maxLength": 256},
    "class": {"type": "string", "enum": ["K", "P", "E", "D"]},
    "product": {"type": "string", "minLength": 1},
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "base_ref"],
      "properties": {
        "mode": {"type": "string", "const": "runtime"},
        "base_ref": {"type": "string", "minLength": 1}
      }
    },
    "claims": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "risk_profile": {"type": "object"},
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["added", "removed", "forbidden"],
      "properties": {
        "added": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "removed": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "forbidden": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supported",
        "strategy",
        "maximum_recovery_time_minutes",
        "data_migration_reversible",
        "irreversible_effects"
      ],
      "properties": {
        "supported": {"type": "boolean"},
        "strategy": {"type": "string"},
        "maximum_recovery_time_minutes": {"type": "integer", "minimum": 1},
        "data_migration_reversible": {"type": "boolean"},
        "irreversible_effects": {"type": "array", "items": {"type": "string"}}
      }
    },
    "self_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "reason"],
      "properties": {
        "required": {"type": "boolean"},
        "reason": {"type": "string"}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["static_ledgers", "runtime_required"],
      "properties": {
        "static_ledgers": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^\\.oak/(active|archive)/pr_[0-9]+/.+\\.jsonl$"
          }
        },
        "runtime_required": {"type": "boolean"}
      }
    }
  }
}
