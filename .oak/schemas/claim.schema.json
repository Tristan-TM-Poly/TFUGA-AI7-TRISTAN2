{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OAKGate Claim v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "statement",
    "type",
    "criticality",
    "status",
    "evidence_required",
    "falsification_criteria",
    "depends_on"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^CLM-[A-Z0-9][A-Z0-9._-]{2,95}$"
    },
    "statement": {
      "type": "string",
      "minLength": 20,
      "maxLength": 4000
    },
    "type": {
      "type": "string",
      "enum": [
        "behavioral",
        "security",
        "scientific",
        "operational",
        "product",
        "documentation"
      ]
    },
    "criticality": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "tested_local",
        "contested"
      ]
    },
    "evidence_required": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "unit_test",
          "integration_test",
          "baseline",
          "reproduction",
          "security_scan",
          "benchmark",
          "review",
          "mutation_test"
        ]
      }
    },
    "falsification_criteria": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 8
      }
    },
    "depends_on": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^CLM-"
      }
    },
    "exclusions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
