{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Omega Hosting OAK Ledger Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action_id",
    "timestamp_utc",
    "actor",
    "intent",
    "asset_class",
    "risk_level",
    "approval_status",
    "rollback_plan",
    "proof",
    "residual_risk"
  ],
  "properties": {
    "action_id": {"type": "string", "pattern": "^OHT-[0-9]{8}-[0-9]{3}$"},
    "timestamp_utc": {"type": "string", "format": "date-time"},
    "actor": {"type": "string"},
    "intent": {"type": "string"},
    "asset_class": {
      "type": "string",
      "enum": ["public_open", "public_marketing", "confidential_ip", "private_personal", "regulated_sensitive", "runtime_private"]
    },
    "risk_level": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
    "approval_status": {"type": "string", "enum": ["not_required", "pending", "approved", "rejected"]},
    "rollback_plan": {"type": "string"},
    "proof": {"type": "string"},
    "residual_risk": {"type": "string"},
    "links": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
