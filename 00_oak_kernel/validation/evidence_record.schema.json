{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tristan-t.omega/schemas/evidence_record.schema.v1.json",
  "title": "Enregistrement canonique Evidence Ledger Tristan-T",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "claim_id",
    "kind",
    "status"
  ],
  "properties": {
    "claim_id": {
      "type": "string",
      "pattern": "^CLM-[A-Z0-9][A-Z0-9._-]{2,63}$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "unit_test",
        "integration_test",
        "baseline",
        "reproduction",
        "security_scan",
        "benchmark",
        "review"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "inconclusive",
        "not_run"
      ]
    },
    "artifact": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "command": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "expected": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "observed": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "environment": {
      "type": "object"
    }
  }
}
