{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tristan-tm-poly.github.io/schemas/omega_gov_qc_t/evidence_item.schema.json",
  "title": "Ω-GOV-QC-T EvidenceItem",
  "type": "object",
  "additionalProperties": false,
  "required": ["evidence_id", "claim", "source_id", "status", "confidence"],
  "properties": {
    "evidence_id": {
      "type": "string",
      "minLength": 1
    },
    "claim": {
      "type": "string",
      "minLength": 1
    },
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["signal", "hypothesis", "structured_evidence", "recommendation", "human_decision"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "method": {
      "type": "string"
    },
    "limitations": {
      "type": "string"
    },
    "counter_explanations": {
      "type": "array",
      "items": {"type": "string"}
    },
    "created_at": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    }
  }
}
