{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tristan-tm-poly.github.io/schemas/omega_gov_qc_t/gov_edge.schema.json",
  "title": "Ω-GOV-QC-T GovEdge",
  "type": "object",
  "additionalProperties": false,
  "required": ["source_id", "target_id", "relation", "evidence", "confidence"],
  "properties": {
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "target_id": {
      "type": "string",
      "minLength": 1
    },
    "relation": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "metadata": {
      "type": "object"
    }
  }
}
