        "properties": {
          "rank": {"type": "integer"},
          "title": {"type": "string"},
          "topic_anchor": {"type": "string"},
          "signal_type": {"type": "array", "items": {"type": "string"}},
          "why_it_matters": {"type": "string"},
          "actionable_opportunity": {"type": "string"},
          "oak_check": {"type": "object"},
          "sources": {"type": "array"},
          "business_funding_signal": {"type": "string"},
          "next_action": {"type": "string"},
          "scores": {"type": "object"}
        }
      }
    },
    "omega_cvcd_synthesis": {"type": "object"}
  }
}
