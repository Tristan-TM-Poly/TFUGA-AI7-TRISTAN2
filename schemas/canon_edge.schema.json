{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tristan-systems.local/schemas/canon_edge.schema.json",
  "title": "CanonEdge",
  "description": "A typed relation between CanonGraph nodes.",
  "type": "object",
  "additionalProperties": false,
  "required": ["edge_id", "source_id", "target_id", "relation", "confidence"],
  "properties": {
    "edge_id": {"type": "string", "minLength": 1},
    "source_id": {"type": "string", "minLength": 1},
    "target_id": {"type": "string", "minLength": 1},
    "relation": {
      "type": "string",
      "enum": ["inspires", "proves", "contradicts", "improves", "replaces", "invalidates", "depends_on", "tests", "falsifies", "implements", "documents", "warns_about", "measures", "quarantines"]
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "oak_notes": {"type": "array", "items": {"type": "string"}}
  }
}
