{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tristan-systems.local/schemas/research_factory_packet.schema.json",
  "title": "ResearchFactoryPacket",
  "description": "Reviewed planning packet for experiments, prototypes, benchmarks, and reusable assets.",
  "type": "object",
  "additionalProperties": false,
  "required": ["branch", "experiment", "benchmark_level", "value_score", "release_status", "factory_line", "safe_next_action"],
  "properties": {
    "branch": {"type": "string", "minLength": 1},
    "experiment": {
      "type": "object",
      "required": ["hypothesis", "baseline", "metric", "success_condition"],
      "properties": {
        "hypothesis": {"type": "string"},
        "baseline": {"type": "string"},
        "metric": {"type": "string"},
        "success_condition": {"type": "string"}
      }
    },
    "benchmark_level": {"type": "string", "pattern": "^B([0-9]|10)_"},
    "value_score": {"type": "integer"},
    "release_status": {"type": "string"},
    "factory_line": {"type": "string"},
    "safe_next_action": {"type": "string"},
    "review_gates": {"type": "array", "items": {"type": "string"}}
  }
}
