{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MethodGraph v0.5",
  "type": "object",
  "required": ["methods", "next_action"],
  "properties": {
    "methods": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["method_id", "method", "atom_ids", "score"],
        "properties": {
          "method_id": { "type": "string" },
          "method": { "type": "string" },
          "atom_ids": { "type": "array", "items": { "type": "string" } },
          "keywords": { "type": "array", "items": { "type": "string" } },
          "inputs": { "type": "array", "items": { "type": "string" } },
          "outputs": { "type": "array", "items": { "type": "string" } },
          "assumptions": { "type": "array", "items": { "type": "string" } },
          "score": { "type": "number", "minimum": 0, "maximum": 1 },
          "domains": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "ready_methods": { "type": "array", "items": { "type": "string" } },
    "needs_more_evidence": { "type": "array", "items": { "type": "string" } },
    "next_action": { "type": "string" }
  }
}
