{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tristan-tm-poly.github.io/schemas/omega-game-t/oakbench_result.schema.json",
  "title": "Ω-GAME-T OAKBenchResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["engine", "quality", "level", "metrics", "notes"],
  "properties": {
    "engine": { "type": "string", "minLength": 1 },
    "quality": { "type": "number", "minimum": 0, "maximum": 1 },
    "level": {
      "type": "string",
      "enum": ["needs_work", "prototype", "good", "excellent", "plus_ultra"]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fun",
        "agency",
        "coherence",
        "learning",
        "safety",
        "novelty",
        "fairness",
        "replayability",
        "friction",
        "exploits",
        "confusion",
        "residue",
        "compression_gain",
        "m_minus_reduction"
      ],
      "properties": {
        "fun": { "type": "number", "minimum": 0, "maximum": 1 },
        "agency": { "type": "number", "minimum": 0, "maximum": 1 },
        "coherence": { "type": "number", "minimum": 0, "maximum": 1 },
        "learning": { "type": "number", "minimum": 0, "maximum": 1 },
        "safety": { "type": "number", "minimum": 0, "maximum": 1 },
        "novelty": { "type": "number", "minimum": 0, "maximum": 1 },
        "fairness": { "type": "number", "minimum": 0, "maximum": 1 },
        "replayability": { "type": "number", "minimum": 0, "maximum": 1 },
        "friction": { "type": "number", "minimum": 0, "maximum": 1 },
        "exploits": { "type": "number", "minimum": 0, "maximum": 1 },
        "confusion": { "type": "number", "minimum": 0, "maximum": 1 },
        "residue": { "type": "number", "minimum": 0, "maximum": 1 },
        "compression_gain": { "type": "number", "minimum": 0, "maximum": 1 },
        "m_minus_reduction": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
