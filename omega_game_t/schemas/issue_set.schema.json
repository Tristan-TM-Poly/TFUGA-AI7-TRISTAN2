{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tristan-tm-poly.github.io/schemas/omega-game-t/issue_set.schema.json",
  "title": "IssueSet",
  "type": "object",
  "required": ["epic_title", "source_theory", "target_engine", "product_name", "milestone", "label_plan", "issues"],
  "properties": {
    "epic_title": { "type": "string" },
    "source_theory": { "type": "string" },
    "target_engine": { "type": "string" },
    "product_name": { "type": "string" },
    "milestone": { "type": "object" },
    "label_plan": { "type": "object" },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "body": { "type": "string" },
          "labels": { "type": "array", "items": { "type": "string" } },
          "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
          "oak_controls": { "type": "array", "items": { "type": "string" } },
          "priority": { "type": "string" }
        }
      }
    }
  }
}
