{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tristan-tm-poly.github.io/schemas/omega-game-t/version_plan.schema.json",
  "title": "VersionPlan",
  "type": "object",
  "required": ["product_name", "target_engine", "version", "release_type", "confidence_score", "changes", "release_criteria", "changelog", "next_actions"],
  "properties": {
    "product_name": { "type": "string" },
    "target_engine": { "type": "string" },
    "version": { "type": "string" },
    "release_type": { "type": "string" },
    "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": { "type": "string" },
          "description": { "type": "string" },
          "source_memory": { "type": "string" },
          "priority": { "type": "string" }
        }
      }
    },
    "release_criteria": {
      "type": "object",
      "properties": {
        "tests": { "type": "array", "items": { "type": "string" } },
        "oak_gates": { "type": "array", "items": { "type": "string" } },
        "memory_checks": { "type": "array", "items": { "type": "string" } },
        "blockers": { "type": "array", "items": { "type": "string" } }
      }
    },
    "changelog": { "type": "array", "items": { "type": "string" } },
    "next_actions": { "type": "array", "items": { "type": "string" } }
  }
}
