{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tristan-tm-poly.github.io/schemas/omega-game-t/world_dna.schema.json",
  "title": "Ω-GAME-T WorldDNA",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "genre", "core_loop", "invariants", "memory"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "genre": { "type": "string", "minLength": 1 },
    "core_loop": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "invariants": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "memory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["positive", "negative"],
      "properties": {
        "positive": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "negative": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    }
  }
}
